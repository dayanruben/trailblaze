#!/bin/bash

# Trailblaze launcher
#
# Usage:
#   ./trailblaze                     - Launch desktop GUI
#   ./trailblaze app --headless      - Start headless daemon
#   ./trailblaze app --stop          - Stop the daemon
#   ./trailblaze blaze "objective"   - Take a UI action (auto-starts daemon)
#   ./trailblaze ask "question"      - Ask about the screen (auto-starts daemon)
#   ./trailblaze trail <file>          - Run a trail file (auto-starts daemon)
#   ./trailblaze mcp                 - Start MCP server (STDIO proxy to daemon)
#   ./trailblaze <command>           - Run other CLI commands (config, report, etc.)
#
# Environment variables:
#   TRAILBLAZE_PORT           - HTTP port (default: 52525). Override to run multiple instances.
#   TRAILBLAZE_HTTPS_PORT     - HTTPS port (default: TRAILBLAZE_PORT + 1). Rarely overridden;
#                               derived so a single TRAILBLAZE_PORT override is enough to run
#                               isolated daemons.
#   TRAILBLAZE_JAR            - Path to the uber JAR (default: trailblaze.jar next to this script)
#   TRAILBLAZE_IPC            - Set to 0 to disable the daemon IPC fast path (default: 1).
#                               The fast path requires `jq` on PATH; if jq is missing the CLI
#                               falls back silently to the JVM path. Install jq to benefit.
#
# Logs are saved automatically by the JVM to ~/.trailblaze/desktop-logs/
# (port-specific filenames for parallel instances).

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ---------------------------------------------------------------------------
# JDK version check
# ---------------------------------------------------------------------------

JAVA_VERSION=$(java -version 2>&1 | head -1 | sed -E 's/.*"([0-9]+).*/\1/')
if [ -n "$JAVA_VERSION" ] && [ "$JAVA_VERSION" -lt 17 ] 2>/dev/null; then
  echo "ERROR: Trailblaze requires JDK 17 or later, but found JDK ${JAVA_VERSION}." >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Execution
# ---------------------------------------------------------------------------

# JVM args required for Compose Desktop on macOS — Skiko's JNI native code needs
# access to internal AWT classes. Without these, java -jar crashes with SIGSEGV.
# Default max heap covers report generation with large session logs.
TRAILBLAZE_JVM_ARGS="-Xmx4g"
if [[ "$(uname)" == "Darwin" ]]; then
  TRAILBLAZE_JVM_ARGS="$TRAILBLAZE_JVM_ARGS --add-opens java.desktop/sun.awt=ALL-UNNAMED --add-opens java.desktop/sun.lwawt=ALL-UNNAMED --add-opens java.desktop/sun.lwawt.macosx=ALL-UNNAMED"
fi

TRAILBLAZE_JAR="${TRAILBLAZE_JAR:-$SCRIPT_DIR/trailblaze.jar}"

# ---------------------------------------------------------------------------
# AppCDS — class data sharing archive for faster JVM startup
# ---------------------------------------------------------------------------
# Generates a .jsa sibling to the JAR on first use, then passes
# -XX:SharedArchiveFile=<path> -Xshare:auto on every subsequent invocation.
#
# Why static CDS (-Xshare:dump) and not dynamic CDS (-XX:ArchiveClassesAtExit):
# dynamic CDS requires a pre-existing base archive (Temurin's default classes.jsa),
# which is NOT shipped in the Temurin 17 macOS build — the JVM fails with
# "DynamicDumpSharedSpaces is unsupported when base CDS archive is not loaded".
# Static CDS builds a standalone archive from a class list with no base needed.
#
# Why a sibling file and not a JAR entry: CDS binds the archive to the exact
# JAR contents (size + mtime) at dump time. Adding the .jsa as a JAR entry
# changes the JAR's fingerprint and makes the archive unusable ("A jar file
# is not the one used while building the shared archive file"). Keeping the
# .jsa outside the JAR preserves the fingerprint.
#
# -Xshare:auto (not :on) means fingerprint mismatches — JVM version skew,
# replaced JAR — silently fall back to standard class loading. Pure upside.
#
# Escape hatch: set BLAZE_CDS=0 to disable. Regenerated automatically when
# the JAR is newer than the .jsa (e.g., after a dev rebuild).

tb_ensure_cds_archive() {
  local jar="$1"
  # The CDS archive path gets injected into unquoted $TRAILBLAZE_JVM_ARGS (same
  # pattern as --add-opens). Bail if the JAR path contains whitespace so we
  # don't word-split the JVM arg and break startup; plain JAR mode still works.
  case "$jar" in *[[:space:]]*) return 1 ;; esac

  local jsa="${jar%.jar}.jsa"

  if [ -f "$jsa" ] && [ ! "$jar" -nt "$jsa" ]; then
    printf '%s' "$jsa"
    return 0
  fi
  [ -w "$(dirname "$jsa")" ] || return 1

  echo "Building CDS archive for faster Trailblaze startup (one-time, ~1.5s)..." >&2
  local classlist tmp_jsa
  classlist="$(mktemp "${TMPDIR:-/tmp}/trailblaze-classlist.XXXXXX")" || return 1
  tmp_jsa="${jsa}.tmp.$$"

  # Class list is dumped from `config show` (not --help) because it exercises
  # CLI parsing + Ktor init for ~60% more coverage without needing a device.
  #
  # After dumping, verify the archive actually loads by running `trail --help`
  # with it. Some JDK 17 builds have a CDS verifier bug with Kotlin enums that
  # manifests as `VerifyError: Bad type on operand stack` when TrailCommand.<init>
  # loads — and that bug is JVM-version-specific, so we need to detect it at
  # generate time rather than pretend it doesn't exist. If the verification
  # command fails, we discard the broken archive and the caller falls back to
  # plain JAR mode for that JAR/JDK combination.
  if java $TRAILBLAZE_JVM_ARGS -XX:DumpLoadedClassList="$classlist" \
         -jar "$jar" config show >/dev/null 2>&1 \
     && java $TRAILBLAZE_JVM_ARGS -XX:SharedClassListFile="$classlist" \
         -XX:SharedArchiveFile="$tmp_jsa" -Xshare:dump \
         -jar "$jar" >/dev/null 2>&1 \
     && java $TRAILBLAZE_JVM_ARGS -XX:SharedArchiveFile="$tmp_jsa" -Xshare:auto \
         -jar "$jar" trail --help >/dev/null 2>&1 \
     && mv -f "$tmp_jsa" "$jsa"; then
    rm -f "$classlist"
    printf '%s' "$jsa"
    return 0
  fi
  rm -f "$classlist" "$tmp_jsa"
  return 1
}

if [ "${BLAZE_CDS:-1}" = "1" ] && [ -f "$TRAILBLAZE_JAR" ]; then
  TRAILBLAZE_CDS_ARCHIVE="$(tb_ensure_cds_archive "$TRAILBLAZE_JAR")"
  if [ -n "$TRAILBLAZE_CDS_ARCHIVE" ]; then
    TRAILBLAZE_JVM_ARGS="$TRAILBLAZE_JVM_ARGS -XX:SharedArchiveFile=$TRAILBLAZE_CDS_ARCHIVE -Xshare:auto"
  fi
fi

# Execution functions — overridable by defining them before sourcing this script.
# All functions accept variadic args to preserve quoting (e.g., YAML with newlines).
if ! declare -f tb_run > /dev/null 2>&1; then
  tb_run() {
    java $TRAILBLAZE_JVM_ARGS -jar "$TRAILBLAZE_JAR" "$@"
  }

  tb_run_background() {
    nohup java $TRAILBLAZE_JVM_ARGS -jar "$TRAILBLAZE_JAR" "$@" > /dev/null 2>&1 &
  }

  tb_run_quiet() {
    # JAR mode has no build noise, so this is the same as tb_run.
    tb_run "$@"
  }

  tb_run_exec_quiet() {
    exec java $TRAILBLAZE_JVM_ARGS -jar "$TRAILBLAZE_JAR" "$@"
  }

  tb_run_background_quiet() {
    nohup java $TRAILBLAZE_JVM_ARGS -jar "$TRAILBLAZE_JAR" "$@" > /dev/null 2>&1 &
  }
fi

# ---------------------------------------------------------------------------
# Port configuration
# ---------------------------------------------------------------------------

TRAILBLAZE_DEFAULT_PORT=52525
TRAILBLAZE_PORT="${TRAILBLAZE_PORT:-$TRAILBLAZE_DEFAULT_PORT}"
# HTTPS defaults to TRAILBLAZE_PORT + 1 so a single port override is enough to
# run multiple daemons in isolation. Mirrors TrailblazeDevicePort's Kotlin-side
# convention (the on-device RPC server defaults to TRAILBLAZE_PORT + 2).
TRAILBLAZE_HTTPS_PORT="${TRAILBLAZE_HTTPS_PORT:-$((TRAILBLAZE_PORT + 1))}"

# Export so the JVM process can read them via System.getenv()
export TRAILBLAZE_PORT
export TRAILBLAZE_HTTPS_PORT

# ---------------------------------------------------------------------------
# Daemon management
# ---------------------------------------------------------------------------

is_daemon_running() {
    curl -s --connect-timeout 1 "http://localhost:${TRAILBLAZE_PORT}/ping" > /dev/null 2>&1
}

# Path to a per-port pidfile recording the JVM PID we spawn for this script.
# Used to detect "JVM is alive but the port is unbound" — i.e. a previous
# auto-start that hung in init before binding HTTP. is_daemon_running() only
# tells us whether the port answers; it can't distinguish "no daemon" from
# "daemon stuck pre-bind", so without this file the next invocation would
# happily spawn another stuck JVM, and another, and another.
TRAILBLAZE_PIDFILE_DIR="${HOME}/.trailblaze"
TRAILBLAZE_PIDFILE="${TRAILBLAZE_PIDFILE_DIR}/daemon-${TRAILBLAZE_PORT}.pid"

# Returns 0 if the PID in the pidfile is still alive (a previous auto-start
# is still running), 1 if no pidfile or the PID is dead. Cleans up stale
# pidfiles as a side-effect.
prior_daemon_pid_alive() {
    [ -f "$TRAILBLAZE_PIDFILE" ] || return 1
    local pid
    pid=$(cat "$TRAILBLAZE_PIDFILE" 2>/dev/null)
    [ -n "$pid" ] || { rm -f "$TRAILBLAZE_PIDFILE"; return 1; }
    if kill -0 "$pid" 2>/dev/null; then
        return 0
    fi
    rm -f "$TRAILBLAZE_PIDFILE"
    return 1
}

# Refuses to spawn a new daemon if the previous JVM we spawned for this port
# is still alive but not responding (i.e. stuck in init). Without this guard,
# every retry adds another zombie JVM consuming ~4 GB of heap.
abort_if_stuck_daemon() {
    if prior_daemon_pid_alive && ! is_daemon_running; then
        local pid
        pid=$(cat "$TRAILBLAZE_PIDFILE" 2>/dev/null)
        echo "" >&2
        echo "ERROR: A Trailblaze daemon (PID $pid) is alive on port ${TRAILBLAZE_PORT}" >&2
        echo "       but is not responding to HTTP. It is likely stuck in startup." >&2
        echo "" >&2
        echo "       Refusing to spawn another daemon — multiple stuck JVMs would" >&2
        echo "       compound the problem." >&2
        echo "" >&2
        echo "       To recover:" >&2
        echo "         kill -9 $pid && rm -f $TRAILBLAZE_PIDFILE" >&2
        echo "" >&2
        echo "       Or set TRAILBLAZE_PORT to an unused port to start a fresh daemon." >&2
        exit 1
    fi
    # No stuck daemon — clear any stale pidfile so the new spawn can write.
    rm -f "$TRAILBLAZE_PIDFILE"
}

# Records the spawned JVM's PID so a subsequent invocation can detect a
# stuck daemon. Called immediately after tb_run_background / tb_run_background_quiet.
record_daemon_pid() {
    mkdir -p "$TRAILBLAZE_PIDFILE_DIR"
    echo "$1" > "$TRAILBLAZE_PIDFILE"
}

# ---------------------------------------------------------------------------
# CLI-via-daemon IPC fast path
# ---------------------------------------------------------------------------
#
# When the daemon is already running, forward argv to it over HTTP instead of
# spinning up a fresh JVM. The daemon runs the picocli command in-process and
# returns {stdout, stderr, exitCode}; this shim prints them and exits.
#
# The daemon is the single source of truth for which subcommands it will run
# in-process (TrailblazeCli.FORWARDABLE_SUBCOMMANDS). Anything else responds
# with forwarded=false and we fall through. We don't mirror the allowlist here
# — the only cost of trying is one localhost round-trip, negligible next to
# the ~1s JVM startup we're about to pay anyway.
#
# Falls through to the normal JVM path if:
#   - jq isn't installed (we can't assemble/parse JSON safely without it)
#   - the daemon is unreachable
#   - the daemon responds with forwarded=false (subcommand not in allowlist)
#   - the curl POST fails for any reason (HTTP error, network blip)
#
# Disable explicitly with `--direct` or `--no-daemon` on the CLI, or by setting
# TRAILBLAZE_IPC=0 in the environment.

# Attempt to run via the daemon's /cli/exec endpoint.
# On success prints stdout/stderr and exits with the daemon's exit code.
# On any form of failure, returns 1 so the caller can fall through.
ipc_try_forward() {
    command -v jq >/dev/null 2>&1 || return 1
    # Build the args JSON array by appending each arg with `jq --arg`, which
    # passes the string through without any in-band delimiter parsing. The
    # previous `printf '%s\n' | jq -R . | jq -s .` pipeline silently split
    # on embedded newlines, corrupting multi-line args (realistic for `ask`
    # prompts that contain quoted code or paragraphs).
    local args_json="[]"
    local a
    for a in "$@"; do
      args_json=$(jq --arg a "$a" '. + [$a]' <<<"$args_json") || return 1
    done
    local payload
    payload=$(jq -n --argjson args "$args_json" '{args: $args}') || return 1

    local response
    response=$(curl -sS --connect-timeout 2 --max-time 600 \
        -X POST "http://localhost:${TRAILBLAZE_PORT}/cli/exec" \
        -H "Content-Type: application/json" \
        -d "$payload" 2>/dev/null) || return 1

    # Daemon returned non-JSON (endpoint missing on older daemon, etc.) — fall through.
    echo "$response" | jq -e . >/dev/null 2>&1 || return 1

    local forwarded
    forwarded=$(echo "$response" | jq -r '.forwarded // false')
    [ "$forwarded" = "true" ] || return 1

    local stdout stderr exit_code
    stdout=$(echo "$response" | jq -r '.stdout // ""')
    stderr=$(echo "$response" | jq -r '.stderr // ""')
    # Clamp exitCode to a shell-valid integer 0-255. jq returns the literal
    # string "null" if the field is missing, and bash `exit "$str"` fails
    # noisily with "numeric argument required" on anything non-numeric.
    exit_code=$(echo "$response" | jq -r '
        if .exitCode | type == "number" then
          (.exitCode | floor | if . < 0 then 256 + (. % 256) elif . > 255 then . % 256 else . end)
        else 1 end
    ')
    [[ "$exit_code" =~ ^[0-9]+$ ]] || exit_code=1

    [ -n "$stdout" ] && printf '%s' "$stdout"
    [ -n "$stderr" ] && printf '%s' "$stderr" >&2
    exit "$exit_code"
}

show_window() {
    curl -s -X POST "http://localhost:${TRAILBLAZE_PORT}/cli/show-window" \
        -H "Content-Type: application/json" \
        -d '{}' > /dev/null 2>&1
}

stop_daemon() {
    if ! is_daemon_running; then
        echo "Trailblaze is not running."
        return 0
    fi

    echo "Stopping Trailblaze..."
    curl -s -X POST "http://localhost:${TRAILBLAZE_PORT}/cli/shutdown" \
        -H "Content-Type: application/json" \
        -d '{}' > /dev/null 2>&1

    attempts=0
    while is_daemon_running && [ $attempts -lt 10 ]; do
        sleep 0.5
        attempts=$((attempts + 1))
    done

    if is_daemon_running; then
        echo "Daemon did not stop gracefully."
        return 1
    else
        rm -f "$TRAILBLAZE_PIDFILE"
        echo "Trailblaze stopped."
        return 0
    fi
}

get_status() {
    if is_daemon_running; then
        echo "Trailblaze is running on port ${TRAILBLAZE_PORT}."
        curl -s "http://localhost:${TRAILBLAZE_PORT}/cli/status" 2>/dev/null | cat
        echo ""
    else
        echo "Trailblaze is not running."
    fi
}

# ---------------------------------------------------------------------------
# Path resolution helper
# ---------------------------------------------------------------------------

to_absolute_path() {
    local path="$1"
    if [ -f "$path" ]; then
        echo "$(cd "$(dirname "$path")" && pwd)/$(basename "$path")"
    elif [ -d "$path" ]; then
        echo "$(cd "$path" && pwd)"
    else
        echo "$path"
    fi
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

# Process arguments: resolve file paths to absolute and detect STDIO mode.
# Uses an array to preserve quoting for arguments with spaces (e.g., --yaml YAML).
STDIO_MODE=false
HAS_MCP=false
HAS_HTTP=false
HAS_DIRECT=false
ARGS_ARRAY=()
for arg in "$@"; do
    if [ "$arg" = "mcp" ]; then
        HAS_MCP=true
    fi
    if [ "$arg" = "--http" ]; then
        HAS_HTTP=true
    fi
    if [ "$arg" = "--direct" ] || [ "$arg" = "--no-daemon" ]; then
        HAS_DIRECT=true
    fi

    # Only resolve paths that look like file/dir references (contain / or .)
    # Don't resolve bare words like "web", "android", "ios" — they're command arguments
    if [[ "$arg" == */* ]] || [[ "$arg" == *.* ]]; then
        resolved_arg=$(to_absolute_path "$arg")
    else
        resolved_arg="$arg"
    fi
    ARGS_ARRAY+=("$resolved_arg")
done
# Flat string for functions that need it (backward compat)
ARGS="${ARGS_ARRAY[*]}"

# STDIO mode: `mcp` subcommand without `--http` flag (includes --bridge mode)
if [ "$HAS_MCP" = true ] && [ "$HAS_HTTP" = false ]; then
    STDIO_MODE=true
fi

# ---------------------------------------------------------------------------
# Main logic
# ---------------------------------------------------------------------------

if [ "$1" = "stop" ]; then
    stop_daemon
elif [ "$1" = "status" ]; then
    get_status
elif [ "${TRAILBLAZE_IPC:-1}" = "1" ] \
    && [ "$HAS_DIRECT" = false ] \
    && [ "$STDIO_MODE" = false ] \
    && is_daemon_running; then
    # Fast path: forward to the already-running daemon instead of spawning a JVM.
    # ipc_try_forward either exits (success) or returns nonzero so we fall through
    # to the normal JVM path below.
    ipc_try_forward "${ARGS_ARRAY[@]}" || tb_run_quiet "${ARGS_ARRAY[@]}"
elif [ "$STDIO_MODE" = true ]; then
    # STDIO MCP mode: quiet output so only JSON-RPC goes to stdout.

    # Auto-start daemon if not running (proxy needs it)
    if ! is_daemon_running; then
        abort_if_stuck_daemon
        echo "[mcp] Starting Trailblaze daemon..." >&2
        # Ports are passed via exported TRAILBLAZE_PORT/TRAILBLAZE_HTTPS_PORT env vars
        tb_run_background_quiet app --foreground --headless
        record_daemon_pid "$!"
        echo "[mcp] Daemon starting (PID $!)..." >&2

        attempts=0
        while [ $attempts -lt 60 ]; do
            if is_daemon_running; then
                echo "[mcp] Daemon ready." >&2
                break
            fi
            sleep 1
            attempts=$((attempts + 1))
        done

        if ! is_daemon_running; then
            echo "[mcp] Warning: daemon did not start in time." >&2
        fi
    fi

    tb_run_exec_quiet "${ARGS_ARRAY[@]}"
elif ([ "$1" = "trail" ] || [ "$1" = "run" ] || [ "$1" = "blaze" ] || [ "$1" = "ask" ] || ([ "$1" = "session" ] && [ "$2" != "info" ]) || [ "$1" = "tools" ]) && ! is_daemon_running; then
    abort_if_stuck_daemon
    # Auto-start daemon for commands that need it so subsequent calls reuse it.
    # Use stderr so --json output on stdout stays clean.
    echo "Starting Trailblaze daemon..." >&2
    # Ports are passed via exported TRAILBLAZE_PORT/TRAILBLAZE_HTTPS_PORT env vars
    tb_run_background app --foreground --headless
    record_daemon_pid "$!"

    # Wait for daemon to be ready (all output to stderr for --json safety)
    echo -n "Waiting for Trailblaze daemon" >&2
    max_attempts=60
    attempts=0
    while [ $attempts -lt $max_attempts ]; do
        if is_daemon_running; then
            echo "" >&2
            echo "Trailblaze daemon ready." >&2
            break
        fi
        echo -n "." >&2
        sleep 1
        attempts=$((attempts + 1))
    done

    if ! is_daemon_running; then
        echo "" >&2
        echo "Warning: Daemon did not start in time. Falling back to direct execution." >&2
    fi

    # Now run the CLI command — TrailCommand will detect the daemon and delegate.
    # Use quiet mode to suppress Gradle build noise from user-facing output.
    tb_run_quiet "${ARGS_ARRAY[@]}"
    RUN_EXIT=$?

    # Keep daemon alive for all commands so subsequent runs reuse it.
    # Use `./trailblaze app --stop` to shut it down explicitly.
    exit $RUN_EXIT
elif [ ${#ARGS_ARRAY[@]} -gt 0 ]; then
    # CLI command mode (config, auth, etc.)
    tb_run_quiet "${ARGS_ARRAY[@]}"
else
    # No subcommand: show help
    tb_run_quiet --help
fi
