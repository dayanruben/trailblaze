// Resolves `@trailblaze/scripting` for `.ts` tool files via the Trailblaze SDK
// bundle (see the `paths` mapping below for the relative location at
// `sdks/typescript/dist/`). That bundle is a build artifact — generated from
// `sdks/typescript/src/` by the Gradle build (any `./gradlew` build that
// packages the SDK, or `trailblaze check`), not committed — so IDE import
// resolution (IntelliJ, VS Code, Cursor) works after the first build, not on a
// bare fresh clone.
//
// Intentionally hand-authored (no `// FRAMEWORK-GENERATED` banner) — the
// framework's `PerTrailmapTsconfigEmitter` writes a different shape whose
// `paths` mapping points at the workspace-local SDK extract at
// `<workspace>/.trailblaze/sdk/dist/`. This committed variant instead points up
// at the repo's `sdks/typescript/dist/` so a single source-tree build covers
// every example. `trailblaze check` detects the missing framework banner and
// preserves this file verbatim.
{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "paths": {
      "@trailblaze/scripting": ["../../../../../../../sdks/typescript/dist/index"],
      "@trailblaze/scripting/*": ["../../../../../../../sdks/typescript/dist/*"]
    }
  },
  "include": ["**/*.ts", "**/*.js"],
  "exclude": ["**/*.test.ts"]
}
