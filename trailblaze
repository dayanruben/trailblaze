#!/bin/bash

# Trailblaze launcher (development)
# Runs from uber JAR when source hasn't changed, or via Gradle otherwise.
# Override TRAILBLAZE_MODULE to use a different module (e.g., :my-custom-host).
#
# Modes:
#   ./trailblaze "command"        - Runs from uber JAR, rebuilding only when source changes (default)
#   ./trailblaze --gradle "cmd"   - Always runs via Gradle (slower but guaranteed fresh)
#   BLAZE_JAR=0 ./trailblaze      - Same as --gradle, via environment variable
#
# Environment variables:
#   TRAILBLAZE_SDK_DIR            - Auto-pinned to $SCRIPT_DIR/sdks/typescript when that
#                                   path exists, so the analyzer-backed enrichment for
#                                   meta-only scripted-tool descriptors resolves from
#                                   any CWD. Override to point at a different SDK tree
#                                   (e.g., installed-CLI setups, tests against a fixture).

TRAILBLAZE_MODULE="${TRAILBLAZE_MODULE:-:trailblaze-desktop}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export TRAILBLAZE_LAUNCHER="${TRAILBLAZE_LAUNCHER:-$SCRIPT_DIR/trailblaze}"

# Auto-pin TRAILBLAZE_SDK_DIR to this repo's `sdks/typescript` when launching from a
# source checkout. The analyzer's walk-up resolver finds the SDK from any CWD under the
# repo tree, but breaks down when the user invokes from the repo root (the walk-up only
# climbs to ancestors, never descends), so meta-only scripted-tool descriptors fail to
# enrich. Pinning here means a user running `./trailblaze check --workspace …/some/trailmap`
# from the repo root gets the same SDK resolution as one running from inside the trailmap.
# Honors a caller-set override so explicit values (installed-CLI setups, tests pointing
# at a fixture SDK) still take precedence.
if [ -z "${TRAILBLAZE_SDK_DIR:-}" ] && [ -f "$SCRIPT_DIR/sdks/typescript/tools/extract-tool-defs.mjs" ]; then
  export TRAILBLAZE_SDK_DIR="$SCRIPT_DIR/sdks/typescript"
fi

source "$SCRIPT_DIR/scripts/dev-jar-cache.sh"

# ---------------------------------------------------------------------------
# JAR mode detection — strip --jar/--gradle flags from arguments
# ---------------------------------------------------------------------------

# In CI, default to Gradle mode — there's no cached uber JAR and building one
# from scratch exceeds the server health-check timeout.
if [[ "${CI:-}" == "true" ]] || [[ "${BUILDKITE:-}" == "true" ]]; then
  BLAZE_JAR="${BLAZE_JAR:-0}"
else
  BLAZE_JAR="${BLAZE_JAR:-1}"
fi
FILTERED_ARGS=()
for arg in "$@"; do
  if [ "$arg" = "--gradle" ]; then
    BLAZE_JAR=0
  elif [ "$arg" = "--jar" ]; then
    BLAZE_JAR=1
  else
    FILTERED_ARGS+=("$arg")
  fi
done
set -- "${FILTERED_ARGS[@]}"

# ---------------------------------------------------------------------------
# JAR mode — resolve or build uber JAR, let production script handle execution
# ---------------------------------------------------------------------------

JAR_DIR=$(dev_jar_dir)

if [ "$BLAZE_JAR" = "1" ]; then
  if dev_ensure_jar "$JAR_DIR"; then
    # JAR is ready — export TRAILBLAZE_JAR so the production script's tb_run*
    # functions use it directly (no Gradle overhead).
    export TRAILBLAZE_JAR="$DEV_JAR_PATH"
  else
    # Build failed — fall back to Gradle mode
    BLAZE_JAR=0
  fi
fi

# ---------------------------------------------------------------------------
# Gradle mode — override tb_run* to use Gradle, pre-cache JAR after success
# ---------------------------------------------------------------------------

if [ "$BLAZE_JAR" != "1" ]; then
  # All gradle invocations run from $DEV_JAR_REPO_ROOT (set by dev-jar-cache.sh,
  # sourced above): MCP clients and IDE integrations spawn this launcher with an
  # arbitrary cwd where `./gradlew` doesn't exist. The forked app JVM's working
  # directory is set by Gradle, not by this cd, so argument resolution for the
  # launched CLI is unchanged.
  tb_run() {
    if [ -n "$1" ]; then
      (cd "$DEV_JAR_REPO_ROOT" && ./gradlew ${TRAILBLAZE_MODULE}:run --args="$1")
    else
      (cd "$DEV_JAR_REPO_ROOT" && ./gradlew ${TRAILBLAZE_MODULE}:run)
    fi
  }

  tb_run_background() {
    # Repo root is passed positionally (like the args) rather than interpolated into the
    # command string, so a path containing quotes can't break the spawned command.
    if [ -n "$1" ]; then
      nohup bash -c "cd \"\$1\" && ./gradlew ${TRAILBLAZE_MODULE}:run --args=\"\$2\"" _ "$DEV_JAR_REPO_ROOT" "$1" > /dev/null 2>&1 &
    else
      nohup bash -c "cd \"\$1\" && ./gradlew ${TRAILBLAZE_MODULE}:run" _ "$DEV_JAR_REPO_ROOT" > /dev/null 2>&1 &
    fi
  }

  tb_run_quiet() {
    local _exit
    if [ ${#ARGS_ARRAY[@]} -gt 0 ]; then
      # Quote args containing spaces so Gradle's --args preserves them
      local quoted_args=""
      for arg in "${ARGS_ARRAY[@]}"; do
        if [[ "$arg" == *" "* ]] || [[ "$arg" == *":"* ]] || [[ "$arg" == *"{"* ]]; then
          arg="\"$arg\""
        fi
        if [ -z "$quoted_args" ]; then
          quoted_args="$arg"
        else
          quoted_args="$quoted_args $arg"
        fi
      done
      (cd "$DEV_JAR_REPO_ROOT" && ./gradlew -q --console=plain ${TRAILBLAZE_MODULE}:run --args="$quoted_args")
    else
      (cd "$DEV_JAR_REPO_ROOT" && ./gradlew -q --console=plain ${TRAILBLAZE_MODULE}:run --args="$1")
    fi
    _exit=$?
    # Rebuild the uber JAR so the next default run (JAR mode) starts instantly.
    if [ $_exit -eq 0 ]; then
      dev_update_jar_cache "$JAR_DIR"
    fi
    return $_exit
  }

  tb_run_exec_quiet() {
    # exec replaces this process, so a plain cd (no subshell) is safe here. Fail loudly if the
    # root is missing — otherwise the exec is silently skipped and the caller sees nothing.
    cd "$DEV_JAR_REPO_ROOT" || { echo "Error: cannot cd to repo root '$DEV_JAR_REPO_ROOT' — not starting Trailblaze." >&2; exit 1; }
    exec ./gradlew -q --console=plain ${TRAILBLAZE_MODULE}:run --args="$1"
  }

  tb_run_background_quiet() {
    # Repo root passed positionally — see tb_run_background.
    nohup bash -c "cd \"\$1\" && ./gradlew -q --console=plain ${TRAILBLAZE_MODULE}:run --args=\"\$2\"" _ "$DEV_JAR_REPO_ROOT" "$1" > /dev/null 2>&1 &
  }
fi

source "$SCRIPT_DIR/scripts/trailblaze"
