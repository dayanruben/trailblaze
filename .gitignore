# Node
node_modules/

# Trailblaze trailmap bundle â€” generated per-trailmap `.d.ts` files emitted by the
# `trailblaze.bundle` Gradle plugin and by `trailblaze check`. Derived from the trailmap
# manifest, regenerated on build, not source-of-truth. Anchored to the per-trailmap tools
# dir so an unrelated future `.trailblaze/` directory elsewhere in the tree (e.g., a
# config dir) isn't silently ignored.
**/trailblaze-config/tools/.trailblaze/
# Same generator, workspace-anchor layout. Per-trailmap output (the typed-tool surface
# `tools/trailblaze-client.d.ts`) sits directly under each trailmap's `tools/`; the
# workspace-level `.trailblaze/sdk/` + `tsconfig.base.json` (written by `trailblaze
# check`) live one level up at `<workspace>/.trailblaze/`.
#
# Authors who want the typed surface as a checked-in API contract (so a fresh clone
# resolves typed `client.tools.<name>(args)` methods in IDEs without any pre-IDE
# bootstrap) can commit `tools/trailblaze-client.d.ts` per trailmap â€” already-tracked
# files are unaffected by these ignore rules. The framework regenerates it
# idempotently for the same toolset.
**/trails/config/trailmaps/*/tools/trailblaze-client.d.ts
**/trails/.trailblaze/

# Daemon-emitted compiled-target output (`trailblaze check` writes per-target YAML
# bundles here from the workspace's `trailmaps/` definitions). Generated and lazy-rebundled
# at daemon init, never edited by hand.
**/trails/config/dist/

# `@trailblaze/scripting` SDK bundles â€” generated at build time from `sdks/typescript/src/`
# (esbuild + dts-bundle-generator), shipped in the JVM jar + Android APK/AAR. They rewrite in
# full on any SDK-source change, so they're build artifacts, not committed source. The Gradle
# packaging tasks regenerate them (`:trailblaze-models:bundleTrailblazeSdkDts`,
# `:trailblaze-scripting-bundle:bundleTrailblazeSdk`, `:trailblaze-common:bundleFrameworkScriptedTools`);
# `bun` on PATH (Hermit-pinned) is the build prerequisite. The committed `bun.lock` pins their
# inputs so regeneration is byte-deterministic.
sdks/typescript/dist/
trailblaze-scripting-bundle/src/jvmAndAndroid/resources/trailblaze/scripting/bundle/trailblaze-sdk-bundle.js
trailblaze-common/src/commonMain/resources/trails/config/trailmaps/trailblaze/tools/*.bundle.js

# Daemon local data â€” settings JSON, cache, in-progress logs. Created in the working
# tree when the daemon's `appDataDirectory` points at the repo (developer convenience
# for "run from source" setups), kept out of version control.
/.trailblaze/

# Python
__pycache__/
*.pyc
/sdks/python/.venv/

# NPM/bun lockfiles â€” ignored globally because most node_modules-using directories
# in this tree (examples, fixtures) deliberately float deps. The ONE exception is
# the framework's TypeScript SDK at `sdks/typescript/`, whose `bun.lock` IS
# committed so the build-time-generated bundles (`trailblaze-sdk-bundle.js`,
# `dist/index.js`, `dist/index.d.ts` â€” see the SDK-bundle rule above) regenerate
# byte-deterministically across CI and developer machines. The bundles themselves are
# NOT committed; only the lockfile that pins their inputs is.
package-lock.json
bun.lock
bun.lockb
!sdks/typescript/bun.lock
# Report-gallery per-trail assets (docs/report-assets/<trail>/): fetched from CI
# artifacts at docs-build time or filled with the generic placeholder by docs_hooks.py.
# Never committed â€” only the generic docs/images/report-pending.webp lives in the repo.
# (Deliberately NOT under docs/generated/, which scripts/generate-docs-and-diff.sh wipes
# and reproducibility-checks.)
docs/report-assets/*/
